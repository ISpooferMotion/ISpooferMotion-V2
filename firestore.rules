rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /assetCache/{document=**} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }

    // Default rule to deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
