{
  "name": "ispoofermotion",
  "version": "2.0.0-rc.5",
  "description": "Animation spoofing utility for Roblox",
  "author": {
    "name": "IncredibroXP",
    "email": "incredibroxpdev@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build:plugin": "bun scripts/build-plugin.mjs",
    "build": "run-s build:app build:plugin",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:dev": "bun scripts/clear-dev-state.mjs && tauri dev",
    "format": "run-s format:prettier format:rust format:stylua",
    "format:check": "run-s format:prettier:check format:rust:check format:stylua:check",
    "format:prettier": "prettier --write .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:stylua": "bunx @johnnymorganz/stylua-bin .",
    "format:prettier:check": "prettier --check .",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:stylua:check": "bunx @johnnymorganz/stylua-bin --check .",
    "typecheck": "tsc --noEmit",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml --lib",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --lib --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "check": "run-s typecheck rust:check rust:lint rust:test lint test build"
  },
  "dependencies": {
    "@codycon/ism-library": "file:./ISM-Library/packages/ui",
    "@floating-ui/react-dom": "^2.1.8",
    "@tanstack/react-query": "^5.101.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "fzstd": "^0.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
