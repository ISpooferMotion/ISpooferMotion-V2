{
  "name": "ispoofermotion",
  "version": "2.1.5",
  "main": "main.js",
  "description": "Animation spoofing utility for Roblox",
  "author": {
    "name": "IncredibroXP",
    "email": "incredibroxpdev@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "make:mac-icon": "bash scripts/make-mac-icon.sh"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "better-sqlite3": "^12.6.0",
    "express": "^5.2.1",
    "form-data": "^4.0.2",
    "keytar": "^7.9.0",
    "roblox-animation-transfer": "^1.3.0"
  },
  "build": {
    "appId": "com.github.IncrediDev.ISpooferMotion",
    "productName": "ISpooferMotion",
    "files": [
      "**/*",
      "!downloads/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app_icon_dark.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/app_icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/app_icon.png",
      "category": "Utility"
    }
  }
}
